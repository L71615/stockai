# ============================================================
# StockAI — 环境变量配置
# 复制此文件为 .env
#   cp .env.example .env
# ============================================================

# --- 运行环境（必须）---
ENV=production
PORT=3000

# --- 安全（必须修改）---
# 生产环境务必更换，用 openssl rand -hex 32 生成
JWT_SECRET=change-me-in-production

# --- AI 供应商（可选）---
# 所有 AI Key 都可以在网页"设置"页填入，存在数据库里
# 这里填的只是服务启动时的兜底值，不填不影响使用
MINIMAX_API_KEY=
DEEPSEEK_API_KEY=
CLAUDE_API_KEY=
OPENAI_API_KEY=
XIAOMI_API_KEY=

# --- 邮件通知（可选）---
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
