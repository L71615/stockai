# ============================================================
# StockAI — 环境变量配置
# 复制此文件为 .env 并填入真实值
#   cp .env.example .env
# ============================================================

# --- 运行环境 ---
ENV=production
PORT=3000

# --- 安全 ---
# 生产环境务必更换 JWT 密钥（任意长随机字符串）
JWT_SECRET=change-me-in-production

# --- AI 供应商（至少配一个）---
# MiniMax（主力）
MINIMAX_API_KEY=
MINIMAX_MODEL=MiniMax-M2.7

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# Claude
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-opus-4-7

# OpenAI
OPENAI_API_KEY=

# 小米
XIAOMI_API_KEY=
XIAOMI_MODEL=mixtral-8x7b

# --- AI 默认供应商 ---
AI_PROVIDER=minimax

# --- 邮件通知（可选）---
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
